# Configuración de __PROJECT__ (copia este archivo a `.env` y ajústalo).
# El `.env` NUNCA se sube a git (lleva secretos).

APP_NAME=__PROJECT__
APP_ENV=local

# --- Base de datos (OBLIGATORIA) ---
# Por default sqlite local. Para otros motores: DATABASE_URL=postgresql+psycopg://...
DATABASE_URL=sqlite:///./__PROJECT__.db

# --- Dónde vive TU código (esto es lo que vuelve a tequio "consciente" de tu proyecto) ---
MODULES_PACKAGE=app.Modules
MODELS_PACKAGE=app.Models
APP_COMMANDS_PACKAGE=app.Console.Commands
APP_DIR=app
MIGRATIONS_DIR=migrations

# --- Colas / broker-agnostic (para @job y @cron_task; OPCIONAL) ---
# BROKER_URL: vacío => redis local por default. Solo se usa para lo ENCOLADO (los
# flujos síncronos no lo tocan). Cambia el transporte sin tocar código:
#   Redis:    redis://localhost:6379/0
#   RabbitMQ: amqp://guest:guest@localhost:5672//      (docker compose ya lo levanta)
BROKER_URL=
# Result backend: OPCIONAL (crons fire-and-forget). Vacío => sin backend.
RESULT_BACKEND_URL=
# Store de locks para without_overlapping (redis). Vacío => redis local por default.
LOCK_URL=
# Reintentos de tasks ante fallos TRANSITORIOS (backoff exponencial con jitter). Son los
# DEFAULTS de retry_policy(); se pueden pisar A MANO en código por-task. Solo afectan a
# tasks que OPTAN por reintentar (autoretry_for), NUNCA a crons. 0 => sin reintentos.
TASK_MAX_RETRIES=3
TASK_RETRY_BACKOFF=2          # segundos base del 1er reintento (luego se duplica)
TASK_RETRY_BACKOFF_MAX=600    # tope del backoff entre reintentos (10 min)

# --- Locale / zona horaria ---
# Si se omite, el default es la zona del HOST. IMPORTANTE fijarla explícita: un
# server suele estar en UTC y quien lo monta puede no ser quien programa.
TIMEZONE=America/Mexico_City
# Locale de Faker para factories/seeders (datos falsos). Cualquier locale de Faker:
# es_MX, es_ES, en_US, pt_BR, ... Default: es_MX.
FAKER_LOCALE=es_MX
# Locale de fallback de i18n (correos, etc.) cuando no se pasa uno explícito.
APP_FALLBACK_LOCALE=es

# --- Correo ---
# MAIL_DRIVER: cómo se manda.  log = lo escribe en el log (default dev, sin SMTP,
# cross-platform) | smtp = SMTP real (apunta a mailpit con docker compose) | null = no-op.
# Con driver=log el correo se VUELCA AL LOG sin tocar SMTP; mailpit (docker compose) lo
# muestra en su UI :8025 cuando usas MAIL_DRIVER=smtp.
MAIL_DRIVER=log
MAIL_HOST=127.0.0.1        # con docker en el host: 127.0.0.1; dentro de un contenedor: mailpit
MAIL_PORT=1025             # SMTP de mailpit (docker compose lo levanta)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=          # "" sin cifrado (mailpit) | tls (STARTTLS) | ssl (SMTPS)
MAIL_FROM_EMAIL=no-reply@__PROJECT__.local
MAIL_FROM_NAME=__PROJECT__

# --- Logging (Loguru) ---
LOG_LEVEL=INFO
# LOG_JSON=true agrega logs/app.jsonl (JSON Lines) para Loki/Grafana.
LOG_JSON=false
